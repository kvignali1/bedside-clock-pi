[Unit]
Description=Bedside Clock Backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=kvignali1
WorkingDirectory=/home/kvignali1/Bedside_clock_pi
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/kvignali1/Bedside_clock_pi/.venv/bin/python /home/kvignali1/Bedside_clock_pi/backend/app.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
